PORT=3000
DATABASE_URL=
REDIS_HOST=saas_redis
REDIS_PORT=6379
WAHA_API_URL=http://saas_waha:3000
# Alias aceito pelo channelProvisioning.service.js
# WAHA_URL=http://saas_waha:3099
# Obrigatório se o WAHA exige API key (X-Api-Key) — igual a WAHA_API_KEY do container saas_waha.
# WAHA_API_KEY=
# Opcional: alias da URL (resolução de auth WAHA)
# WAHA_BASE_URL=http://localhost:3099
# WAHA: modo CORE (criação automática de API key) — só se x-api-key/apikey falharem
# WAHA_DASHBOARD_USERNAME=admin
# WAHA_DASHBOARD_PASSWORD=
EVOLUTION_API_URL=
# Alias aceito pelo channelProvisioning.service.js
# EVOLUTION_URL=http://saas_evolution:8080
EVOLUTION_API_KEY=
# URL pública da API para receber webhooks dos providers:
# API_BASE_URL=https://api.omnia1biai.com.br
AUTHENTICATION_API_KEY=

# Sessão WhatsApp / multi-instância (opcional)
# WHATSAPP_DISTRIBUTED_LOCK_DISABLED=false
# WHATSAPP_DISTRIBUTED_LOCK_TTL_MS=120000
# WHATSAPP_DISTRIBUTED_LOCK_MAX_WAIT_MS=60000
# WHATSAPP_ENSURE_OPERATION_TIMEOUT_MS=180000
# WHATSAPP_CONNECT_OPERATION_TIMEOUT_MS=210000
# WHATSAPP_HEALTHCHECK_TIMEOUT_MS=20000
# WHATSAPP_QR_REST_TIMEOUT_MS=12000
# WHATSAPP_SESSION_CB_FAILURE_THRESHOLD=5
# WHATSAPP_SESSION_CB_OPEN_MS=45000
# WAHA_SESSION_DEBUG_POLL=0
HEALTH_MONITOR_CONCURRENCY=5
