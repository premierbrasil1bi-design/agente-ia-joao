# Formato: CHAVE=valor (sem espaços em torno do =).
# Valores com espaços ou caracteres especiais (& ? | $ ` #) devem ir entre aspas duplas, ex.:
#   DISPLAY_NAME="Dra Ana Paula"
#   DATABASE_URL="postgresql://neondb_owner:npg_JC9VIyrMFo1U@ep-wandering-paper-ahogquzh.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
#
# development | production (config valida e loga avisos no startup)
NODE_ENV=development

# Porta em que o backend escuta (frontend admin usa VITE_API_URL apontando para esta porta)
PORT=3000

# Chave de API da OpenAI (ChatGPT)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# PostgreSQL Neon
# Sem DATABASE_URL, o painel usa dados simulados.
DATABASE_URL=postgresql://neondb_owner:npg_JC9VIyrMFo1U@ep-wandering-paper-ahogquzh.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT para autenticação do painel admin (obrigatório em produção)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# JWT exclusivo AGENTE IA OMNICANAL (painel agent_token / agent_user)
AGENT_JWT_SECRET=agent_ia_super_secret_key
AGENT_JWT_EXPIRES_IN=1d

# Redis — fila BullMQ (Evolution).
# Em produção (PM2 no host), use localhost.
REDIS_URL=redis://127.0.0.1:6379

# WAHA — quando channels.provider = waha (docker: porta host 3099 → 3000 no container)
# WAHA_API_KEY= opcional; configure o mesmo no WAHA se usar autenticação
WAHA_URL=http://127.0.0.1:3099
# WAHA_API_KEY=

# TTL do cache Redis para GET fetchInstances (segundos; clamp 10–30; padrão 20)
# EVOLUTION_INSTANCES_CACHE_TTL_SEC=20

# Worker Evolution no mesmo processo do API (padrão). Para API sem worker: false + rode npm run worker:evolution
# EVOLUTION_WORKER_IN_PROCESS=true

# Evolution API – integração WhatsApp (Client App → Channels)
# URL da Evolution API (ex.: http://localhost:8080 ou http://saas_evolution:8080 no Docker)
EVOLUTION_API_URL=http://localhost:8080
# Obrigatório se EVOLUTION_API_URL estiver definida (o backend encerra o startup se faltar). Mesmo valor que AUTHENTICATION_API_KEY no container Evolution.
EVOLUTION_API_KEY=
# Opcional: uso legado sem EVOLUTION_API_URL (ex. scripts). Com URL definida, não substitui EVOLUTION_API_KEY.
AUTHENTICATION_API_KEY=
# Configure na Evolution o webhook global (ou por instância) para: https://<sua-api>/api/evolution/webhook
# (também existe POST /webhooks/evolution e /api/webhooks/whatsapp/evolution conforme deploy antigo)
# TTL (segundos) para deduplicação de messages.upsert no Redis (padrão 300)
# EVOLUTION_WEBHOOK_DEDUP_TTL_SEC=300
#
# Alerta quando há mais de um canal evolution para o mesmo external_id (tabela system_errors + log [EVOLUTION][ALERT_SENT])
# Rate limit por external_id no Redis (SET NX); repetidos no período → [EVOLUTION][ALERT_SKIPPED_RATE_LIMIT]
# EVOLUTION_INVARIANT_ALERT_TTL_SEC=60
# EVOLUTION_INVARIANT_WEBHOOK_URL=https://hooks.slack.com/services/...  # opcional: Slack, Zapier, etc.
# EVOLUTION_INVARIANT_WEBHOOK_TIMEOUT_MS=3500
