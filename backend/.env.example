# Formato: CHAVE=valor (sem espaços em torno do =).
# Valores com espaços ou caracteres especiais (& ? | $ ` #) devem ir entre aspas duplas, ex.:
#   DISPLAY_NAME="Dra Ana Paula"
#   DATABASE_URL="postgresql://user:pass@host/db?sslmode=require&channel_binding=require"
#
# development | production (config valida e loga avisos no startup)
NODE_ENV=development

# Porta em que o backend escuta (frontend admin usa VITE_API_URL apontando para esta porta)
PORT=3000

# Chave de API da OpenAI (ChatGPT)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Neon (PostgreSQL) – connection string do projeto
# Sem DATABASE_URL, o painel usa dados simulados.
# Obtenha em: https://console.neon.tech → Connection string
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# JWT para autenticação do painel admin (obrigatório em produção)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# JWT exclusivo AGENTE IA OMNICANAL (painel agent_token / agent_user)
AGENT_JWT_SECRET=agent_ia_super_secret_key
AGENT_JWT_EXPIRES_IN=1d

# Redis — obrigatório para fila BullMQ (Evolution). Com Docker: redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# Worker Evolution no mesmo processo do API (padrão). Para API sem worker: false + rode npm run worker:evolution
# EVOLUTION_WORKER_IN_PROCESS=true

# Evolution API – integração WhatsApp (Client App → Channels)
# URL da Evolution API (ex.: http://localhost:8080)
EVOLUTION_API_URL=http://localhost:8080
# API Key da Evolution (ex.: EVOLUTION_2026_JOAO_998877)
EVOLUTION_API_KEY=
